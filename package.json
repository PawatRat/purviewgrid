{
  "name": "purviewgrid",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "npm run build:vite && npm run build:electron",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:vite": "vite build",
    "build:electron": "electron-builder"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-masonry-css": "^1.0.16"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.4",
    "wait-on": "^9.0.4",
    "electron": "^41.2.0"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.purview.app",
    "mac": {
      "category": "public.app-category.photography"
    },
    "fileAssociations": [
      {
        "ext": [
          "png",
          "jpg",
          "jpeg",
          "gif",
          "webp",
          "bmp"
        ],
        "name": "Image File",
        "role": "Viewer"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ]
  },
  "author": "Purview",
  "description": "A masonry image viewer"
}